# ─── Copy this file to .env and fill in your values ──────────────────────────

# Database
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/ecosphere_esg?schema=public"

# JWT Secrets (use strong random strings in production)
JWT_SECRET="change-this-to-a-strong-random-secret-min-32-chars"
JWT_REFRESH_SECRET="change-this-to-a-different-strong-random-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"

# Email / SMTP (optional — for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="EcoSphere ESG <noreply@ecosphere.com>"
